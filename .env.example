# Django settings
SECRET_KEY=your-strong-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com,localhost,127.0.0.1

# Render Blueprints populate DATABASE_URL from the attached Render Postgres
# database automatically. Do not set it manually for that deployment path.
#
# For Supabase, copy the Session pooler URI from the Connect dialog exactly.
# The username must be postgres.<project-ref>, not just postgres.
# DATABASE_URL=postgresql://postgres.your_project_ref:YOUR_URL_ENCODED_PASSWORD@aws-your-region.pooler.supabase.com:5432/postgres?sslmode=require
